<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HUD Fair Housing Office — AI Agent Build Plan</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --hud-navy: #002D62;
    --hud-blue: #0057A8;
    --hud-sky: #1B8FD4;
    --accent: #E8A020;
    --accent2: #2ECC9A;
    --red: #D94F3D;
    --bg: #F0F4FA;
    --card: #FFFFFF;
    --text: #0A1628;
    --muted: #6B7B99;
    --border: #C8D5E8;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'IBM Plex Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /* HEADER */
  .header {
    background: var(--hud-navy);
    padding: 0;
    position: relative;
    overflow: hidden;
  }
  .header::before {
    content: '';
    position: absolute;
    top: -60px; right: -80px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(0,87,168,0.5) 0%, transparent 70%);
    pointer-events: none;
  }
  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 36px 40px 30px;
    display: flex;
    align-items: flex-start;
    gap: 24px;
  }
  .hud-seal {
    width: 72px; height: 72px;
    background: var(--accent);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px; font-weight: 800;
    color: var(--hud-navy);
    flex-shrink: 0;
    box-shadow: 0 0 0 4px rgba(232,160,32,0.3);
  }
  .header-text h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 38px;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.5px;
    line-height: 1;
  }
  .header-text h1 span { color: var(--accent); }
  .header-text p {
    font-size: 13px;
    color: #8AABCC;
    margin-top: 6px;
    font-family: 'IBM Plex Mono', monospace;
    letter-spacing: 0.5px;
  }
  .header-meta {
    margin-left: auto;
    text-align: right;
  }
  .header-meta .badge {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: #aac4e0;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 3px;
    display: inline-block;
    margin-bottom: 6px;
  }
  .header-meta .total-agents {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 48px;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
  }
  .header-meta .total-label {
    font-size: 11px;
    color: #8AABCC;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* SUMMARY STRIP */
  .summary-strip {
    background: var(--hud-blue);
    padding: 14px 40px;
    display: flex;
    gap: 40px;
    max-width: 100%;
    overflow-x: auto;
  }
  .summary-strip .stat {
    display: flex;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
  }
  .summary-strip .stat-val {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: #fff;
  }
  .summary-strip .stat-label {
    font-size: 11px;
    color: #9ABFE0;
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }
  .divider { width: 1px; background: rgba(255,255,255,0.2); }

  /* LEGEND */
  .legend {
    max-width: 1400px;
    margin: 28px auto 0;
    padding: 0 40px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
  }
  .legend-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-right: 4px;
  }
  .legend-item {
    display: flex; align-items: center; gap: 6px;
    font-size: 12px;
    color: var(--text);
  }
  .legend-dot {
    width: 10px; height: 10px;
    border-radius: 2px;
  }

  /* MAIN TABLE AREA */
  .table-wrap {
    max-width: 1400px;
    margin: 20px auto 40px;
    padding: 0 40px;
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    background: var(--card);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 2px 20px rgba(0,45,98,0.08);
  }

  thead {
    background: var(--hud-navy);
  }
  thead th {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #c0d5ee;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    padding: 14px 16px;
    text-align: left;
    white-space: nowrap;
    border-bottom: 2px solid var(--hud-sky);
  }
  thead th:first-child { border-radius: 10px 0 0 0; }
  thead th:last-child { border-radius: 0 10px 0 0; }

  .category-row td {
    background: #E8EEF8;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--hud-navy);
    padding: 10px 16px;
    border-top: 2px solid var(--border);
  }
  .category-row .cat-icon {
    margin-right: 8px;
  }

  tbody tr:not(.category-row) {
    transition: background 0.15s;
  }
  tbody tr:not(.category-row):hover {
    background: #F5F8FF;
  }
  tbody tr:not(.category-row) td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
    vertical-align: top;
  }

  .agent-name {
    font-weight: 600;
    color: var(--hud-navy);
    font-size: 13.5px;
    white-space: nowrap;
  }
  .agent-desc {
    font-size: 11.5px;
    color: var(--muted);
    margin-top: 2px;
  }

  /* TIME PILL */
  .time-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    border-radius: 20px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11.5px;
    font-weight: 600;
    white-space: nowrap;
  }
  .time-short { background: #D4F5E8; color: #1A7A56; }
  .time-medium { background: #FFF3D4; color: #8A6010; }
  .time-long { background: #FFE8E6; color: #9A2A20; }

  /* PLATFORM BADGE */
  .platform-cell {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .plat-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 9px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    white-space: nowrap;
    width: fit-content;
  }
  .plat-dynamics { background: #E6F0FF; color: #0057A8; border: 1px solid #B8D0F0; }
  .plat-copilot { background: #EDE6FF; color: #5B1AB8; border: 1px solid #C9B8F0; }
  .plat-power { background: #E6F7FF; color: #0078B8; border: 1px solid #B8E0F0; }
  .plat-azure { background: #E8F8FF; color: #006B9A; border: 1px solid #9ED4EE; }
  .plat-purview { background: #F0E6FF; color: #6B00B8; border: 1px solid #D0B8EE; }

  /* AI BADGE */
  .ai-cell {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .ai-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 9px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    white-space: nowrap;
    width: fit-content;
  }
  .ai-claude { background: #FFF3E6; color: #C05800; border: 1px solid #F0CCB0; }
  .ai-copilot { background: #E6F0FF; color: #003F8A; border: 1px solid #B0CCF0; }
  .ai-azure { background: #E0F4FF; color: #005A8A; border: 1px solid #9DCEED; }
  .ai-gpt { background: #E8F8EE; color: #1A6B3A; border: 1px solid #9EDAB8; }
  .ai-perplexity { background: #E8F0E8; color: #2A5A2A; border: 1px solid #9EBE9E; }

  /* PRIORITY */
  .priority {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: 50%;
    margin-right: 4px;
  }
  .p-high { background: var(--red); }
  .p-med { background: var(--accent); }
  .p-low { background: var(--accent2); }

  .priority-cell {
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
  }
  .p-high-text { color: var(--red); }
  .p-med-text { color: #B07010; }
  .p-low-text { color: #1A8060; }

  /* TOTAL ROW */
  .total-row td {
    background: var(--hud-navy);
    color: #fff;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 700;
    padding: 14px 16px;
    letter-spacing: 0.5px;
  }
  .total-row td:first-child { border-radius: 0 0 0 10px; }
  .total-row td:last-child { border-radius: 0 0 10px 0; }

  /* FOOTNOTES */
  .footnotes {
    max-width: 1400px;
    margin: 0 auto 60px;
    padding: 0 40px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .footnote-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 18px 20px;
    box-shadow: 0 1px 8px rgba(0,45,98,0.05);
  }
  .footnote-card h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 15px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--hud-navy);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .footnote-card p, .footnote-card li {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.7;
  }
  .footnote-card ul {
    padding-left: 16px;
  }

  @media (max-width: 900px) {
    .footnotes { grid-template-columns: 1fr; }
    .header-meta { display: none; }
  }
</style>
</head>
<body>

<div class="header">
  <div class="header-inner">
    <div class="hud-seal">HUD</div>
    <div class="header-text">
      <h1>Fair Housing Office — <span>AI Agent Build Plan</span></h1>
      <p>PLATFORM: MICROSOFT DYNAMICS 365 + COPILOT STUDIO &nbsp;|&nbsp; MARCH 2026</p>
    </div>
    <div class="header-meta">
