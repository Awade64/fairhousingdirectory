      <td><span class="plat-badge plat-dynamics">⚙ Dynamics 365</span></td>
      <td><div class="ai-cell"><span class="ai-badge ai-claude">🟠 Claude (Anthropic)</span><span class="ai-badge ai-azure">🔷 Azure OpenAI</span></div></td>
      <td><span class="priority p-high"></span><span class="priority-cell p-high-text">High</span></td>
    </tr>
    <tr>
      <td>5</td>
      <td><div class="agent-name">Pattern Detection Agent</div><div class="agent-desc">Systemic discrimination trends</div></td>
